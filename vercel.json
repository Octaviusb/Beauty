{
  "version": 2,
  "builds": [
    { "src": "server/server.js", "use": "@vercel/node" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/products", "dest": "server/server.js" },
    { "src": "/api/wompi-link", "dest": "server/server.js" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
